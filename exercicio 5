import java.util.Scanner;
public class Main {
    public static void main(String args[]) {

        Scanner e=new Scanner(System.in);

        String escolha=  "";
    while(!escolha.equals("S"))
        {
            System.out.println("informe a primeira nota");
            double n1 = e.nextDouble();
            System.out.println("informe a segunda nota");
            double n2 = e.nextDouble();
            System.out.println("======menu de opção======");
            System.out.println("M = media ");
            System.out.println("P =produto entre os numero ");
            System.out.println("D = divisão entre os numeros ");
            System.out.println("S = sair");
            System.out.println("======menu de opção======");
            System.out.println("escolha a opção");
            escolha = e.next().toUpperCase();



            switch (escolha) {

                case ("M"):
                    double media = (n1 + n2) / 2;
                    System.out.println("a media é " + media);
                    break;
                case ("P"):
                    double produto = n1 * n2;
                    System.out.println("o produto final é " + produto);
                    break;
                case ("D"):
                    double divisao = n1 / n2;
                    System.out.println("a divisão dos numeros é " + divisao);
                    break;
                default:
                    System.out.println("obrigado por usar o sistema ");


            }
        }
        e.close();
    }
}
