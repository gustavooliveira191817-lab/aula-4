import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner e = new Scanner(System.in);

        System.out.println("Informe seu plano de trabalho");
        System.out.println("--------------------------");
        System.out.println("Plano A");
        System.out.println("Plano B");
        System.out.println("Plano C");
        System.out.println("--------------------------");

        String plano = e.nextLine().toUpperCase();

        System.out.print("Informe seu salário: ");
        double salario = e.nextDouble();

        double nsalario = 0;

        switch (plano) {
            case "A":
                nsalario = salario + (salario * 0.10);
                break;

            case "B":
                nsalario = salario + (salario * 0.15);
                break;

            case "C":
                nsalario = salario + (salario * 0.20);
                break;

            default:
                System.out.println("Plano informado inválido");
                return;
        }

        System.out.println("O novo salário é: " + nsalario);
    }
}
